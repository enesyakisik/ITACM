rules_version = '2';

// IT Asset Control Pro — Firestore Security Rules
//
// Strategy: every MUTATION goes through the backend API (firebase-admin
// bypasses these rules). Clients get read-only access scoped by the `role`
// custom claim that is cryptographically embedded in their ID token.
// Direct client writes are denied everywhere.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function hasAnyRole() {
      return isSignedIn() && role() in ['Owner', 'Admin', 'Helpdesk', 'Viewer'];
    }

    // A user may always read their own profile; Admins may read any profile.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || role() in ['Owner', 'Admin']);
      allow write: if false;
    }

    // Inventory data: readable by any authenticated IT user, writable only
    // via the backend (transactions + audit logging enforced server-side).
    match /employees/{doc}       { allow read: if hasAnyRole(); allow write: if false; }
    match /assets/{doc}          { allow read: if hasAnyRole(); allow write: if false; }
    match /licenses/{doc}        { allow read: if hasAnyRole(); allow write: if false; }
    match /consumables/{doc}     { allow read: if hasAnyRole(); allow write: if false; }
    match /handovers/{doc}       { allow read: if hasAnyRole(); allow write: if false; }
    match /maintenanceLogs/{doc} { allow read: if hasAnyRole(); allow write: if false; }

    // Software zimmet assignments: readable by any IT user, written via API.
    match /licenseAssignments/{doc} { allow read: if hasAnyRole(); allow write: if false; }

    // Audit trails: Viewers cannot browse raw audit/login logs.
    match /assetHistory/{doc} {
      allow read: if isSignedIn() && role() in ['Owner', 'Admin', 'Helpdesk'];
      allow write: if false;
    }
    match /loginLogs/{doc} {
      allow read: if isSignedIn() && role() in ['Owner', 'Admin'];
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
