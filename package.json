{
  "name": "itacm",
  "version": "1.0.0",
  "description": "IT Asset Control Pro — self-hostable IT asset management backend with switchable PostgreSQL or Firebase backends",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "setup": "node scripts/setup.js",
    "migrate": "node src/providers/postgres/migrate.js",
    "seed:demo": "node scripts/seed-demo.js",
    "set-role": "node scripts/setUserRole.js",
    "lint": "node --check server.js && node --check api/index.js && find src scripts -name '*.js' -exec node --check {} +"
  },
  "keywords": [
    "it-asset-management",
    "inventory",
    "firebase",
    "postgres",
    "express",
    "self-hosted"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^13.10.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4"
  },
  "author": "Enes Yakışık",
  "repository": {
    "type": "git",
    "url": "https://github.com/enesyakisik/itacm.git"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
